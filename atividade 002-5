import java.util.Scanner;

public class AreaPiramide {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        
        System.out.print("Digite o lado da base quadrada: ");
        double ladoBase = scanner.nextDouble();
        
        System.out.print("Digite o apótema lateral da pirâmide: ");
        double apotema = scanner.nextDouble();
        
        double areaBase = ladoBase * ladoBase;
        double areaLateral = 2 * ladoBase * apotema;
        double areaTotal = areaBase + areaLateral;
        
        System.out.println("A área total da pirâmide é: " + areaTotal);
    }
}
